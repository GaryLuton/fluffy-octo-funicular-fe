# Anthropic API key (required) - your Claude API key
ANTHROPIC_API_KEY=sk-ant-xxxxx

# JWT secret for auth tokens (required in production - use a random string)
JWT_SECRET=change-me-to-a-random-secret

# Port (Railway sets this automatically)
PORT=3000

# Database path (optional - defaults to ./stuflover.db)
# DATABASE_PATH=./stuflover.db

# Allowed CORS origins (comma-separated, optional - allows all if not set)
# ALLOWED_ORIGINS=https://stuflover.vercel.app,https://yourdomain.com

# Resend API key (required for password reset emails)
RESEND_API_KEY=re_xxxxx

# From address for password reset emails (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Admin dashboard credentials (required for /admin.html access)
ADMIN_EMAIL=your-admin@email.com
ADMIN_PASSWORD=your-secure-admin-password
